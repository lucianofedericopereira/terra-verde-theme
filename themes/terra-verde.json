    "tokenColors": [
        { "name": "Comments", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#8A8778" } },
        { "name": "Keywords", "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#5A7A52" } },
        { "name": "Operators", "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.comparison", "keyword.operator.logical"], "settings": { "foreground": "#7A6A50" } },
        { "name": "Strings", "scope": ["string", "string.quoted", "string.template", "string.quoted.single", "string.quoted.double"], "settings": { "foreground": "#8B6F4E" } },
        { "name": "String interpolation", "scope": ["punctuation.definition.template-expression", "punctuation.section.embedded"], "settings": { "foreground": "#B07A3E" } },
        { "name": "Regex", "scope": ["string.regexp", "constant.other.character-class.regexp"], "settings": { "foreground": "#4A8A7A" } },
        { "name": "Functions", "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#3A6A42" } },
        { "name": "Function parameters", "scope": ["variable.parameter"], "settings": { "foreground": "#5A6A4A", "fontStyle": "italic" } },
        { "name": "Types and classes", "scope": ["entity.name.type", "entity.name.class", "support.class", "entity.other.inherited-class", "support.type"], "settings": { "foreground": "#6B5D4A" } },
        { "name": "Interfaces", "scope": ["entity.name.type.interface", "entity.name.type.parameter"], "settings": { "foreground": "#4A7A6E", "fontStyle": "italic" } },
        { "name": "Variables", "scope": ["variable", "variable.other", "variable.other.readwrite"], "settings": { "foreground": "#4A5D3A" } },
        { "name": "Language variables", "scope": ["variable.language", "variable.language.this", "variable.language.self", "variable.language.super"], "settings": { "foreground": "#DA7756", "fontStyle": "italic" } },
        { "name": "Object properties", "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property", "meta.object-literal.key"], "settings": { "foreground": "#5A6A4A" } },
        { "name": "Constants", "scope": ["constant", "constant.numeric", "constant.language", "constant.language.boolean", "constant.character", "support.constant"], "settings": { "foreground": "#B07A3E" } },
        { "name": "HTML tags", "scope": ["entity.name.tag", "punctuation.definition.tag"], "settings": { "foreground": "#5A7A52" } },
        { "name": "HTML attributes", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#8B6F4E" } },
        { "name": "Vue directives", "scope": ["entity.other.attribute-name.html.vue", "punctuation.separator.key-value.html"], "settings": { "foreground": "#4A7A6E" } },
        { "name": "Blade directives", "scope": ["keyword.blade", "support.function.construct.begin.blade", "support.function.construct.end.blade"], "settings": { "foreground": "#3A7A52", "fontStyle": "bold" } },
        { "name": "CSS properties", "scope": ["support.type.property-name.css", "support.type.vendored.property-name.css"], "settings": { "foreground": "#4A6A5E" } },
        { "name": "CSS selectors", "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": { "foreground": "#5A7A52" } },
        { "name": "CSS values", "scope": ["support.constant.property-value.css", "meta.property-value.css"], "settings": { "foreground": "#8B6F4E" } },
        { "name": "CSS units", "scope": ["keyword.other.unit.css"], "settings": { "foreground": "#B07A3E" } },
        { "name": "PHP variables", "scope": ["variable.other.php", "punctuation.definition.variable.php"], "settings": { "foreground": "#4A5D3A" } },
        { "name": "PHP namespaces", "scope": ["punctuation.separator.inheritance.php", "support.other.namespace.php"], "settings": { "foreground": "#7A7870" } },
        { "name": "JSON keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#5A7A52" } },
        { "name": "YAML keys", "scope": ["entity.name.tag.yaml"], "settings": { "foreground": "#5A7A52" } },
        { "name": "TOML keys", "scope": ["keyword.key.toml", "entity.name.section.toml"], "settings": { "foreground": "#5A7A52" } },
        { "name": "Punctuation", "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator", "punctuation.accessor"], "settings": { "foreground": "#7A7870" } },
        { "name": "Markdown headings", "scope": ["markup.heading", "entity.name.section", "punctuation.definition.heading.markdown"], "settings": { "foreground": "#3A6A42", "fontStyle": "bold" } },
        { "name": "Markdown bold", "scope": ["markup.bold"], "settings": { "foreground": "#5A4A3A", "fontStyle": "bold" } },
        { "name": "Markdown italic", "scope": ["markup.italic"], "settings": { "foreground": "#6B5D4A", "fontStyle": "italic" } },
        { "name": "Markdown code", "scope": ["markup.inline.raw", "markup.fenced_code.block"], "settings": { "foreground": "#4A6A5E" } },
        { "name": "Markdown links", "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#2E6B5E" } },
        { "name": "Markdown link title", "scope": ["string.other.link.title.markdown"], "settings": { "foreground": "#8B6F4E" } },
        { "name": "Markdown list markers", "scope": ["punctuation.definition.list.begin.markdown"], "settings": { "foreground": "#DA7756" } },
        { "name": "Decorators", "scope": ["meta.decorator", "meta.decorator entity.name.function", "punctuation.decorator"], "settings": { "foreground": "#B07A3E", "fontStyle": "italic" } },
        { "name": "Imports", "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.control.as"], "settings": { "foreground": "#6B8A5A" } },
        { "name": "Built-in support", "scope": ["support.type.builtin", "support.module"], "settings": { "foreground": "#4A7A6E" } },
        { "name": "Embedded", "scope": ["meta.embedded", "source.groovy.embedded"], "settings": { "foreground": "#2C2C2C" } }
    ],
    "semanticTokenColors": {
        "namespace": "#6B5D4A",
        "type": "#6B5D4A",
        "type.declaration": { "foreground": "#6B5D4A", "bold": true },
        "class": "#6B5D4A",
        "class.declaration": { "foreground": "#6B5D4A", "bold": true },
        "interface": { "foreground": "#4A7A6E", "italic": true },
        "enum": "#6B5D4A",
        "enumMember": "#B07A3E",
        "function": "#3A6A42",
        "function.declaration": { "foreground": "#3A6A42", "bold": true },
        "method": "#3A6A42",
        "method.declaration": { "foreground": "#3A6A42", "bold": true },
        "property": "#5A6A4A",
        "variable": "#4A5D3A",
        "variable.readonly": "#5A6A4A",
        "variable.declaration": "#4A5D3A",
        "parameter": { "foreground": "#5A6A4A", "italic": true },
        "string": "#8B6F4E",
        "number": "#B07A3E",
        "keyword": "#5A7A52",
        "modifier": "#5A7A52",
        "comment": "#8A8778",
        "regexp": "#4A8A7A",
        "operator": "#7A6A50",
        "decorator": { "foreground": "#B07A3E", "italic": true },
        "macro": "#DA7756",
        "label": "#8B6F4E",
